{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++11",
                "-stdlib=libc++",
                "-lglfw3",
                "-lglew",
                "-framework",
                "OpenGL",
                "-framework",
                "IOKit",
                "-framework",
                "Cocoa",
                "-I",
                "../OpenGLTemplate/include/",
                "-Wno-deprecated-declarations",
                "-g",
                "-o",
                "sample_debug",
                "Source.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++11",
                "-stdlib=libc++",
                "-lglfw3",
                "-lglew",
                "-framework",
                "OpenGL",
                "-framework",
                "IOKit",
                "-framework",
                "Cocoa",
                "-I",
                "../OpenGLTemplate/include/",
                "-Wno-deprecated-declarations",
                "-O2",
                "-o",
                "sample_release",
                "Source.cpp"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
